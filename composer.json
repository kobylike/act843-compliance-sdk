{
    "name": "ghanacompliance/act843-sdk",
    "description": "Privacy‑preserving compliance monitoring SDK for Ghana Act 843",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0",
        "league/csv": "^9.0",
        "livewire/livewire": "^3.0|^4.0"
    },
    "suggest": {
        "barryvdh/laravel-dompdf": "Required to generate PDF compliance reports."
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "GhanaCompliance\\Act843SDK\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GhanaCompliance\\Act843SDK\\ComplianceServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}